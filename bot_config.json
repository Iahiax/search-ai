  "environment_variables": {
    "required": [
      {
        "name": "TELEGRAM_BOT_TOKEN",
        "description": "رمز بوت تليجرام (من @BotFather).",
        "example": "1234567890:ABCdefGHIjklMNOpqrsTUVwxyz",
        "how_to_get": [
          "1. افتح @BotFather على تليجرام.",
          "2. أرسل /newbot.",
          "3. اتبع التعليمات للحصول على الرمز."
        ]
      },
      {
        "name": "TELEGRAM_CHAT_ID",
        "description": "معرف دردشة تليجرام (يمكن أن يكون رقمًا أو رقمًا سالبًا للمجموعات).",
        "example": "987654321",
        "how_to_get": [
          "1. أرسل رسالة إلى بوتك (مثال: /start).",
          "2. افتح المتصفح واذهب إلى: https://api.telegram.org/bot<TOKEN>/getUpdates",
          "3. ابحث عن chat.id في الاستجابة."
        ]
      }
    ],
    "optional": [
      {
        "name": "REPLICATE_API_TOKEN",
        "description": "رمز API لـ Replicate (لمسح نماذج Replicate).",
        "example": "r8_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
        "how_to_get": [
          "1. سجل الدخول إلى Replicate: https://replicate.com/",
          "2. اذهب إلى: https://replicate.com/account",
          "3. انسخ الرمز من قسم API Token."
        ]
      },
      {
        "name": "KAGGLE_API_TOKEN",
        "description": "رمز API لـ Kaggle (لمسح نماذج Kaggle).",
        "example": "XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
        "how_to_get": [
          "1. سجل الدخول إلى Kaggle: https://www.kaggle.com/",
          "2. اذهب إلى: https://www.kaggle.com/account",
          "3. انقر على Create New Token.",
          "4. ستحصل على ملف kaggle.json، انسخ قيمة key."
        ]
      },
      {
        "name": "SIEM_URL",
        "description": "رابط خادم Elasticsearch أو Splunk.",
        "example": "http://localhost:9200",
        "how_to_get": [
          "1. إذا كنت تستخدم Elasticsearch محليًا: http://localhost:9200",
          "2. إذا كنت تستخدم Elastic Cloud: https://your-cluster-id.region.gcp.cloud.es.io:9243",
          "3. إذا كنت تستخدم Splunk: https://your-splunk-server:8088"
        ]
      },
      {
        "name": "SIEM_API_KEY",
        "description": "مفتاح API لـ Elasticsearch أو Splunk.",
        "example": "VuaCfGx... (Elasticsearch) أو your_hec_token (Splunk)",
        "how_to_get": [
          "1. لـ Elasticsearch: اذهب إلى Security > API Keys في Kibana.",
          "2. لـ Splunk: اذهب إلى Settings > Data Inputs > HTTP Event Collector."
        ]
      }
    ]
  },

